{
  "name": "twrpg-helper",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "build:electron": "ELECTRON_BUILD=true vite build",
    "preview": "vite preview --host 0.0.0.0",
    "electron:dev": "ELECTRON_START_URL=http://localhost:5173 electron .",
    "electron:preview": "npm run build:electron && electron .",
    "electron:dist": "npm run build:electron && electron-builder --mac dmg --x64 --arm64 --win zip --x64 --publish never"
  },
  "build": {
    "appId": "com.twrpg.helper",
    "productName": "TWRPG Helper",
    "artifactName": "TWRPG-Helper-${version}-${os}-${arch}.${ext}",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.utilities"
    },
    "win": {
      "target": [
        "zip"
      ]
    }
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "electron": "^36.0.0",
    "electron-builder": "^26.8.1"
  }
}
